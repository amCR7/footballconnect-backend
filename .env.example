# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/footballconnect"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-seguro-min-32-chars"
JWT_REFRESH_SECRET="otro-secreto-diferente-para-refresh-tokens"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Cloudflare R2
R2_ACCOUNT_ID="tu-account-id"
R2_ACCESS_KEY_ID="tu-access-key"
R2_SECRET_ACCESS_KEY="tu-secret-key"
R2_BUCKET_NAME="footballconnect-media"
R2_PUBLIC_URL="https://media.tu-dominio.com"

# Firebase (push notifications)
FIREBASE_PROJECT_ID="tu-proyecto"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
